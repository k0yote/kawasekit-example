# RFC-0001 — ZeroDev session-key e2e JPYC payment on Polygon Amoy.
# Copy the needed vars into the repo-root `.env` (gitignored). UNAUDITED / testnet only.
# Chain: Amoy, id 80002, native gas POL. Never reuse value-bearing keys here.

# --- RPC / ZeroDev (Amoy project) ---
# Public Amoy RPC (reads + the on-chain decimals() assertion).
AMOY_RPC=
# ZeroDev bundler+paymaster RPC for the Amoy project (ZeroDev dashboard).
# e.g. https://rpc.zerodev.app/api/v2/bundler/<projectId>  /  .../paymaster/<projectId>
ZERODEV_RPC=
ZERODEV_PROJECT_ID=

# --- JPYC on Amoy ---
# MUST be filled from the OFFICIAL JPYC faucet/docs and verified on Amoy PolygonScan.
# The harness asserts on-chain decimals() == JPYC_DECIMALS at startup and aborts on mismatch,
# and asserts this address equals kawasekit's getJpycAddress(80002) (transferJpyc resolves the
# JPYC address from kawasekit's built-in deployments — this env var is the verification anchor).
JPYC_ADDRESS_AMOY=
JPYC_DECIMALS=

# --- keys (testnet-only; never reused from any value-bearing context) ---
OWNER_PRIVATE_KEY=
SESSION_PRIVATE_KEY=

# --- demo recipient (the single allowlisted merchant) ---
MERCHANT_ADDRESS=

# --- demo policy knobs (optional; sane defaults in env.ts) ---
# MAX_PER_TRANSFER_JPYC=1        # human JPYC per transfer (cap)
# MAX_TRANSFERS=1               # window-total count
# WINDOW_SECONDS=3600           # validUntil = now + this
