# kawasekit-example — environment template. Copy to .env; NEVER commit a filled-in .env.
# UNAUDITED — testnet only.

# ============================================================================
# server/ — the metered API (x402 resource server + self-facilitator on Amoy)
# ============================================================================
# The facilitator EOA broadcasts the settle tx and pays GAS only — it never holds
# the payer's JPYC. A stolen facilitator key is a gas-drain/DoS, not fund theft.
X402_FACILITATOR_PRIVATE_KEY=0x...
# Where the JPYC payment is sent (the API operator's address).
X402_RECIPIENT=0x...
# Price per paid call, in human JPYC.
PRICE_JPYC=0.001
# Server port + Amoy RPC (a default public RPC is used if unset).
PORT=8787
POLYGON_AMOY_RPC_URL=

# ============================================================================
# agent/ — the paying agent (pays via the cryptographic 2-of-2 co-signer)
# ============================================================================
# Where to buy from (the server above).
API_BASE_URL=http://127.0.0.1:8787
DEMO_CITY=Tokyo
# Defence-in-depth budget ceiling for the wrapping fetch, in JPYC base units
# (6 decimals). The owner's on-chain cumulative cap is the authoritative limit.
MAX_SPEND_BASE_UNITS=1000000

# --- the cryptographic co-signer (your deployed cosign_server) --------------
# The deployed owner backend (kawasekit-mpc-2p `cosign_server`) over wss + mTLS.
COSIGNER_URL=wss://cosigner.example.com:8443
# The AGENT's one DKLs share (hex), provisioned at the DKG ceremony. This is
# NOT the whole key — no valid signature exists without the owner's co-sign.
AGENT_SHARE_HEX=0x...
# The A3 pre-shared HMAC key (hex), shared with the backend at the DKG ceremony.
A3_KEY_HEX=0x...
# mTLS material (file paths). The agent presents a client cert; the backend
# verifies it (mutual TLS). Provide real PEM files; do not commit them.
COSIGNER_CA_PEM=./secrets/cosigner-ca.pem
COSIGNER_CLIENT_CERT_PEM=./secrets/agent-client.pem
COSIGNER_CLIENT_KEY_PEM=./secrets/agent-client.key
# SNI / cert-identity override when connecting by IP (optional).
COSIGNER_SERVERNAME=
# The bound policy session (the backend holds the authoritative policy).
COSIGNER_SESSION_ID=session-1
COSIGNER_SESSION_NOT_AFTER=4000000000
